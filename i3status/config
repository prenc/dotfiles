# i3status configuration file.
# Installed by dotfiles/install.sh at ~/.config/i3status/config

general {
        colors = true
        interval = 5
}

order += "battery all"
order += "cpu_usage"
order += "disk /"
order += "memory"
order += "tztime local"

battery all {
        format = "󰁹 %percentage (%status) %remaining"
        format_down = "󰂎 n/a"
        status_chr = "charging"
        status_bat = "discharging"
        status_unk = "unknown"
        status_full = "full"
        status_idle = "idle"
}

cpu_usage {
        format = "󰻠 %usage"
}

disk "/" {
        format = "󰋊 %avail"
}

memory {
        format = "󰍛 %used / %available"
        threshold_degraded = "1G"
        format_degraded = "󰍛 low: %available"
}

tztime local {
        format = "󰥔 %Y-%m-%d %H:%M:%S"
}
